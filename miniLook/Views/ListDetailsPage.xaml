<Page
    x:Class="miniLook.Views.ListDetailsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:ctLayouts="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:graph="using:Microsoft.Graph.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:miniConverters="using:miniLook.Converters"
    xmlns:models="using:miniLook.Models"
    x:Name="MailListPage"
    mc:Ignorable="d">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="boolToVisConverter" />
        <converters:StringFormatConverter x:Key="stringFormatConverter" />
        <converters:BoolNegationConverter x:Key="boolNegationConverter" />
        <miniConverters:IsReadToOpacityConverter x:Key="isReadToOpacityConverter" />
        <miniConverters:GraphDateTimeConverter x:Key="graphDateConverter" />
        <miniConverters:StringNavigateUriConverter x:Key="stringUriConverter" />


        <DataTemplate x:Key="ItemTemplate" x:DataType="models:ConversationGroup">

            <Border
                Margin="-6,0,-4,0"
                PointerEntered="ConversationItem_PointerEntered"
                PointerExited="ConversationItem_PointerExited">
                <Border.Resources>
                    <FontIconSource x:Key="ArchiveIcon" Glyph="&#xE7B8;" />
                    <FontIconSource x:Key="ReadIcon" Glyph="&#xE8C3;" />
                    <SwipeItems x:Key="right" Mode="Execute">
                        <SwipeItem
                            BehaviorOnInvoked="RemainOpen"
                            IconSource="{StaticResource ArchiveIcon}"
                            Invoked="ArchiveSwipeItem_Invoked"
                            Text="Archive" />
                    </SwipeItems>
                    <SwipeItems x:Key="left" Mode="Execute">
                        <SwipeItem
                            BehaviorOnInvoked="Close"
                            IconSource="{StaticResource ReadIcon}"
                            Invoked="ReadSwipeItem_Invoked"
                            Text="Mark All Read" />
                    </SwipeItems>
                </Border.Resources>

                <SwipeControl LeftItems="{StaticResource left}" RightItems="{StaticResource right}">
                    <StackPanel>
                        <Grid Height="60">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid Width="20" VerticalAlignment="Center">
                                <Border
                                    Width="10"
                                    Height="10"
                                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                                    CornerRadius="5"
                                    ToolTipService.ToolTip="This conversation has unread messages"
                                    Visibility="{x:Bind LatestMessage.IsRead, Converter={StaticResource boolToVisConverter}, ConverterParameter=true, Mode=OneWay}" />
                                <Button
                                    Width="20"
                                    Height="20"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    CornerRadius="10"
                                    Command="{Binding ElementName=MailListPage, Path=ViewModel.ToggleConversationReadCommand}"
                                    CommandParameter="{x:Bind}"
                                    ToolTipService.ToolTip="Toggle read/unread"
                                    Visibility="{x:Bind IsHovered, Mode=OneWay, Converter={StaticResource boolToVisConverter}}">
                                    <Grid>
                                        <FontIcon
                                            FontSize="12"
                                            Glyph="&#xE8C3;"
                                            Visibility="{x:Bind LatestMessage.IsRead, Converter={StaticResource boolToVisConverter}, ConverterParameter=true, Mode=OneWay}" />
                                        <FontIcon
                                            FontSize="12"
                                            Glyph="&#xE715;"
                                            Visibility="{x:Bind LatestMessage.IsRead, Converter={StaticResource boolToVisConverter}, Mode=OneWay}" />
                                    </Grid>
                                </Button>
                            </Grid>
                            <Grid
                                Grid.Column="1"
                                Margin="{StaticResource SmallLeftMargin}"
                                VerticalAlignment="Center"
                                ColumnSpacing="2"
                                Opacity="{x:Bind LatestMessage.IsRead, Mode=OneWay, Converter={StaticResource isReadToOpacityConverter}}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="auto" />
                                    <RowDefinition Height="auto" />
                                </Grid.RowDefinitions>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Style="{StaticResource ListTitleStyle}"
                                    Text="{x:Bind Subject}" />
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Style="{StaticResource ListSubTitleStyle}"
                                    Text="{x:Bind Sender}" />
                                <Viewbox
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Height="16">
                                    <SymbolIcon Symbol="Calendar" Visibility="{x:Bind IsEvent}" />
                                </Viewbox>
                                <Viewbox
                                    Grid.Row="0"
                                    Grid.Column="2"
                                    Height="16">
                                    <SymbolIcon Symbol="Attach" Visibility="{x:Bind HasAttachments}" />
                                </Viewbox>
                                <Border
                                    Grid.Row="0"
                                    Grid.RowSpan="2"
                                    Grid.Column="3"
                                    Height="20"
                                    MinWidth="20"
                                    Padding="4,0"
                                    VerticalAlignment="Center"
                                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                                    CornerRadius="10"
                                    Visibility="{x:Bind HasMultipleMessages}">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="11"
                                        Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                        Text="{x:Bind MessageCount}" />
                                </Border>
                            </Grid>
                            <Grid
                                Grid.Column="2"
                                Margin="4,0"
                                VerticalAlignment="Center"
                                Visibility="{x:Bind HasMultipleMessages}">
                                <FontIcon
                                    FontSize="12"
                                    Glyph="&#xE76C;"
                                    Visibility="{x:Bind IsExpanded, Converter={StaticResource boolToVisConverter}, ConverterParameter=true, Mode=OneWay}" />
                                <FontIcon
                                    FontSize="12"
                                    Glyph="&#xE76F;"
                                    Visibility="{x:Bind IsExpanded, Converter={StaticResource boolToVisConverter}, Mode=OneWay}" />
                            </Grid>
                            <Button
                                Grid.Column="3"
                                Width="28"
                                Height="28"
                                Padding="0"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                CornerRadius="4"
                                Command="{Binding ElementName=MailListPage, Path=ViewModel.ArchiveConversationCommand}"
                                CommandParameter="{x:Bind}"
                                ToolTipService.ToolTip="Archive"
                                Visibility="{x:Bind IsHovered, Mode=OneWay, Converter={StaticResource boolToVisConverter}}">
                                <FontIcon FontSize="14" Glyph="&#xE7B8;" />
                            </Button>
                            <Grid.ContextFlyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem
                                        x:Name="ArchiveContextMenuItem"
                                        Command="{Binding ElementName=MailListPage, Path=ViewModel.ArchiveConversationCommand}"
                                        CommandParameter="{x:Bind}"
                                        Text="Archive">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon FontSize="14" Glyph="&#xE7B8;" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem
                                        x:Name="MarkReadContextMenuItem"
                                        Command="{Binding ElementName=MailListPage, Path=ViewModel.MarkConversationAsReadCommand}"
                                        CommandParameter="{x:Bind}"
                                        Text="Mark All As Read">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon FontSize="14" Glyph="&#xE8C3;" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem
                                        x:Name="PopOutContextMenuItem"
                                        Command="{Binding ElementName=MailListPage, Path=ViewModel.PopOutConversationCommand}"
                                        CommandParameter="{x:Bind}"
                                        Text="Pop out">
                                        <MenuFlyoutItem.Icon>
                                            <SymbolIcon Symbol="NewWindow" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                </MenuFlyout>
                            </Grid.ContextFlyout>
                        </Grid>

                        <ItemsRepeater ItemsSource="{x:Bind Messages}" Visibility="{x:Bind IsExpanded, Converter={StaticResource boolToVisConverter}, Mode=OneWay}">
                            <DataTemplate x:DataType="models:MailData">
                                <Button
                                    Margin="20,1,0,1"
                                    Padding="8,6"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Command="{Binding ElementName=MailListPage, Path=ViewModel.NavigateToDetailCommand}"
                                    CommandParameter="{x:Bind}"
                                    CornerRadius="4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border
                                            Width="8"
                                            Height="8"
                                            VerticalAlignment="Center"
                                            Background="{ThemeResource AccentFillColorDefaultBrush}"
                                            CornerRadius="4"
                                            Visibility="{x:Bind IsRead, Converter={StaticResource boolToVisConverter}, ConverterParameter=true, Mode=OneWay}" />
                                        <Grid
                                            Grid.Column="1"
                                            Margin="8,0,0,0"
                                            VerticalAlignment="Center">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="auto" />
                                                <RowDefinition Height="auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Style="{StaticResource ListSubTitleStyle}" Text="{x:Bind Sender}" />
                                            <TextBlock
                                                Grid.Row="1"
                                                Opacity="0.7"
                                                Style="{StaticResource ListSubTitleStyle}"
                                                Text="{x:Bind Body}" />
                                        </Grid>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsRepeater>
                    </StackPanel>
                </SwipeControl>
            </Border>
        </DataTemplate>


    </Page.Resources>

    <Grid x:Name="ContentArea">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="170" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <ToggleButton
                    x:Name="CalendarToggleButton"
                    Width="48"
                    Style="{StaticResource DefaultToggleButtonStyle}"
                    ToolTipService.ToolTip="Show a couple of events in the next couple days">
                    <SymbolIcon Symbol="Calendar" />
                </ToggleButton>
                <Grid x:Name="SelectorBarContainer">
                    <SelectorBar
                        x:Name="FocusedOtherSelectorBar"
                        SelectionChanged="FocusedOtherSelectorBar_SelectionChanged"
                        SizeChanged="FocusedOtherSelectorBar_SizeChanged">
                        <SelectorBarItem
                            x:Name="FocusedSelectorBarItem"
                            IsSelected="True"
                            Text="Focused" />
                        <SelectorBarItem x:Name="OtherSelectorBarItem" Text="Other" />
                    </SelectorBar>
                    <InfoBadge
                        x:Name="FocusedInfoBadge"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        IsHitTestVisible="False"
                        Visibility="{x:Bind ViewModel.HasFocusedUnread, Mode=OneWay, Converter={StaticResource boolToVisConverter}}"
                        Value="{x:Bind ViewModel.FocusedUnreadCount, Mode=OneWay}" />
                    <InfoBadge
                        x:Name="OtherInfoBadge"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        IsHitTestVisible="False"
                        Visibility="{x:Bind ViewModel.HasOtherUnread, Mode=OneWay, Converter={StaticResource boolToVisConverter}}"
                        Value="{x:Bind ViewModel.OtherUnreadCount, Mode=OneWay}" />
                </Grid>
                <FontIcon
                    x:Name="NoNetworkIcon"
                    Margin="6"
                    FontSize="16"
                    Foreground="{ThemeResource SystemControlErrorTextForegroundBrush}"
                    Glyph="&#xF384;"
                    ToolTipService.ToolTip="No network"
                    Visibility="{x:Bind ViewModel.HasInternet, Mode=OneWay, Converter={StaticResource boolToVisConverter}, ConverterParameter=true}" />
                <ProgressRing
                    Width="16"
                    Height="16"
                    Margin="6"
                    VerticalAlignment="Center"
                    IsActive="{x:Bind ViewModel.IsLoadingContent, Mode=OneWay}" />
            </StackPanel>

            <CommandBar
                Grid.Column="1"
                Background="Transparent"
                DefaultLabelPosition="Right">
                <CommandBar.PrimaryCommands>
                    <AppBarButton
                        x:Name="PopOutButton"
                        Click="PopOutButton_Click"
                        LabelPosition="Collapsed"
                        ToolTipService.ToolTip="Pop out to separate window">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="NewWindow" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton
                        x:Name="ComposeNewMailButton"
                        Command="{x:Bind ViewModel.GoToSendMailCommand}"
                        Icon="Mail"
                        Label="Compose"
                        ToolTipService.ToolTip="Write a new email">
                        <AppBarButton.KeyboardAccelerators>
                            <KeyboardAccelerator Key="N" Modifiers="Control" />
                        </AppBarButton.KeyboardAccelerators>
                    </AppBarButton>
                    <AppBarButton
                        Command="{x:Bind ViewModel.GoToOutlookCommand}"
                        Icon="Go"
                        Label="Outlook.com"
                        ToolTipService.ToolTip="Go To Outlook.com" />
                </CommandBar.PrimaryCommands>
                <CommandBar.SecondaryCommands>
                    <AppBarButton
                        Command="{x:Bind ViewModel.RefreshCommand}"
                        Icon="Refresh"
                        Label="Refresh">
                        <AppBarButton.KeyboardAccelerators>
                            <KeyboardAccelerator Key="F5" />
                        </AppBarButton.KeyboardAccelerators>
                    </AppBarButton>
                    <AppBarButton Command="{x:Bind ViewModel.SignOutCommand}" Label="Sign out">
                        <AppBarButton.Icon>
                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xF3B1;" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarToggleButton x:Name="DebugViewToggleItem" Label="Debug Log">
                        <AppBarToggleButton.Icon>
                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xEBE8;" />
                        </AppBarToggleButton.Icon>
                    </AppBarToggleButton>
                    <AppBarButton
                        Command="{x:Bind ViewModel.NavigateToSettingsCommand}"
                        Icon="Setting"
                        Label="Settings" />
                </CommandBar.SecondaryCommands>
            </CommandBar>
        </Grid>
        <Grid
            Grid.Row="1"
            Padding="12"
            Background="{ThemeResource ControlFillColorSecondary}"
            Visibility="{x:Bind CalendarToggleButton.IsChecked, Converter={StaticResource boolToVisConverter}, Mode=OneWay}">
            <ItemsRepeater ItemsSource="{x:Bind ViewModel.Events, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <ctLayouts:WrapLayout HorizontalSpacing="12" VerticalSpacing="12" />
                </ItemsRepeater.Layout>
                <DataTemplate x:DataType="graph:Event">
                    <Grid
                        MinWidth="140"
                        Padding="2"
                        CornerRadius="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                        </Grid.RowDefinitions>

                        <TextBlock HorizontalAlignment="Stretch" Text="{x:Bind Subject}" />
                        <StackPanel
                            Grid.Row="1"
                            HorizontalAlignment="Left"
                            Orientation="Horizontal">
                            <HyperlinkButton
                                NavigateUri="{x:Bind OnlineMeetingUrl, Converter={StaticResource stringUriConverter}}"
                                ToolTipService.ToolTip="Online meeting link"
                                Visibility="{x:Bind IsOnlineMeeting.Value, Converter={StaticResource boolToVisConverter}}">
                                <Viewbox Height="14">
                                    <SymbolIcon Symbol="Globe" />
                                </Viewbox>
                            </HyperlinkButton>
                            <HyperlinkButton NavigateUri="{x:Bind WebLink}" ToolTipService.ToolTip="See this event on Outlook.com">
                                <Viewbox Height="14">
                                    <FontIcon Glyph="&#xE8AD;" />
                                </Viewbox>
                            </HyperlinkButton>
                            <TextBlock
                                Grid.Row="1"
                                VerticalAlignment="Center"
                                Text="{x:Bind Converter={StaticResource graphDateConverter}}" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ItemsRepeater>
        </Grid>
        <ListView
            x:Name="MailListView"
            Grid.Row="2"
            Background="Transparent"
            BorderBrush="Transparent"
            IsItemClickEnabled="True"
            ItemClick="MailListView_ItemClick"
            ItemTemplate="{StaticResource ItemTemplate}"
            ItemsSource="{x:Bind ViewModel.FilteredConversationGroups, Mode=OneWay}"
            PointerExited="MailListView_PointerExited"
            SelectionMode="None">
            <ListView.Footer>
                <HyperlinkButton
                    Margin="8,4,8,12"
                    Padding="12,8"
                    HorizontalAlignment="Stretch"
                    Command="{x:Bind ViewModel.LoadMoreMonthsCommand}"
                    ToolTipService.ToolTip="Extend the loaded email history by one more month"
                    Visibility="{x:Bind ViewModel.HasOlderMail, Mode=OneWay, Converter={StaticResource boolToVisConverter}}">
                    <StackPanel
                        HorizontalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="8">
                        <SymbolIcon Symbol="Download" />
                        <TextBlock Text="Load 1 more month of email" />
                    </StackPanel>
                </HyperlinkButton>
            </ListView.Footer>
        </ListView>

        <Grid
            x:Name="DebugPane"
            Grid.Row="2"
            MinWidth="200"
            MinHeight="150"
            Margin="10"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
            CornerRadius="4"
            Visibility="{x:Bind DebugViewToggleItem.IsChecked, Mode=OneWay, Converter={StaticResource boolToVisConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid
                Padding="8"
                BorderBrush="{StaticResource AccentFillColorDefaultBrush}"
                BorderThickness="0,0,0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    VerticalAlignment="Center"
                    FontFamily="Cascadia Code"
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    Text="debug pane" />
                <ToggleButton
                    x:Name="DebugPaneToggleButton"
                    Grid.Column="1"
                    IsChecked="{x:Bind DebugViewToggleItem.IsChecked, Mode=TwoWay}"
                    Style="{StaticResource DefaultToggleButtonStyle}">
                    <Viewbox Height="14">
                        <SymbolIcon Symbol="Clear" />
                    </Viewbox>
                </ToggleButton>
            </Grid>
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Visible">
                <TextBlock
                    x:Name="DebugText"
                    Margin="10,10"
                    IsTextSelectionEnabled="True"
                    Text="{x:Bind ViewModel.DebugText, Mode=OneWay}"
                    TextWrapping="WrapWholeWords" />
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
